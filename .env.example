# --- AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database (PostgreSQL) ---
# Local example:
DATABASE_URL=postgresql://your_db_user@localhost:5432/glemma

# Optional split DB vars (not used directly in code right now, but useful for clarity)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=glemma

# --- Better Auth ---
BETTER_AUTH_SECRET=generate_a_long_random_secret
BETTER_AUTH_URL=http://localhost:3000

# Optional (currently not required by code, keep only if you use them)
BETTER_AUTH_USERNAME=
BETTER_AUTH_PASSWORD=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Dodo Payments ---
DODO_PAYMENTS_API_KEY=your_dodo_payments_api_key
DODO_PAYMENTS_WEBHOOK_SECRET=your_dodo_payments_webhook_secret
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_GLOW_ID=your_glow_product_id
DODO_PRODUCT_GLOW_PRO_ID=your_glow_pro_product_id

